"help" = "🌰 Použití:\n  kastan route|from to\n  kastan station\n  kastan suggest <text> [-T alias] [-o text|markdown|json] [-l count]\n  kastan stations <name> [-T alias] [-o text|markdown|json] [-l count]\n  kastan connections route|from to|-f place -t place [-V place] [-T alias] [-d d.m.yyyy] [-m h:mm] [-a|-p] [-x] [-X count] [-M minutes] [-c] [-v] [-o text|markdown|json|ics] [-l count]\n  kastan departures station|-f place|-s place [-T alias] [-d d.m.yyyy] [-m h:mm] [-a|-p] [-v] [-o text|markdown|json] [-l count]\n  kastan station-timetables -L line -f stop -t direction [-T alias] [-d d.m.yyyy] [-w] [-o text|markdown|json]\n  kastan service <service-id> [-o text|markdown|json]\n  kastan aliases list|add|remove|path [-o text|markdown|json]\n  kastan timetables [-o text|markdown|json]\n\n⚙️ Možnosti:\n  -h, --help              Zobrazí nápovědu\n  --version               Zobrazí verzi aplikace\n  --language, --lang      Jazyk výstupu: en nebo cs (výchozí podle systému)\n  -f, --from              Výchozí místo nebo stanice\n  -t, --to                Cílové místo nebo směrová zastávka\n  -s, --station           Stanice pro odjezdy nebo příjezdy\n  -L, --line              Linka MHD pro zastávkové jízdní řády\n  -T, --timetable         Alias jízdního řádu nebo URL slug IDOSu\n  -d, --date              Datum hledání\n  -m, --time              Čas hledání\n  -w, --whole-week        Zobrazí zastávkový jízdní řád na celý týden\n  -a, --arrival           Hledá podle času příjezdu místo odjezdu\n  -p, --departure         Hledá podle času odjezdu\n  -V, --via               Místo na trase; pro více míst volbu opakujte\n  -x, --direct            Jen přímá spojení\n  -c, --add-to-calendar   Otevře první nalezené spojení jako import iCalendar\n  -v, --verbose           Zobrazí ID výsledků a spojů, tarifní zóny, nástupiště, dopravce a zpoždění\n  -X, --max-transfers     Nejvyšší povolený počet přestupů včetně 0\n  -M, --min-transfer-time Nejkratší doba na přestup v minutách včetně 0\n  -o, --format            Formát výstupu: text, markdown, json nebo ics pro spojení\n  -l, --limit             Nejvyšší počet vypsaných výsledků\n\nVýchozí jízdní řád je vlakyautobusymhdvse.\nAliasy zastávek jsou uloženy v ~/.config/kastan/aliases.json, pokud není nastavena proměnná KASTAN_ALIAS_DATABASE.";
